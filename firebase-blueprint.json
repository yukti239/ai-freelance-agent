{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user information and reputation scores.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "photoURL": { "type": "string" },
        "walletBalance": { "type": "number" },
        "role": { "type": "string", "enum": ["employer", "freelancer"] },
        "pfiScore": { "type": "number", "description": "Professional Fidelity Index (0-1000)" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "Represents a freelance project managed by the AI agent.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "employerId": { "type": "string" },
        "freelancerId": { "type": "string" },
        "totalBudget": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "open", "active", "completed", "disputed"] },
        "escrowStatus": { "type": "string", "enum": ["unfunded", "funded", "released", "refunded"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "employerId", "totalBudget", "status"]
    },
    "Milestone": {
      "title": "Milestone",
      "description": "A specific task within a project with its own budget and AI verification.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "budget": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "submitted", "approved", "rejected"] },
        "aiFeedback": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["projectId", "title", "budget", "status"]
    },
    "Submission": {
      "title": "Submission",
      "description": "Work submitted by a freelancer for a milestone.",
      "type": "object",
      "properties": {
        "milestoneId": { "type": "string" },
        "projectId": { "type": "string" },
        "freelancerId": { "type": "string" },
        "content": { "type": "string", "description": "The submitted work or link to it" },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["milestoneId", "projectId", "freelancerId", "content"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or agent notifications for the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "payout"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial records for wallet deposits and escrow payments.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["deposit", "payment", "withdrawal"] },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "projectId": { "type": "string" }
      },
      "required": ["userId", "amount", "type", "description", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/projects/{projectId}": { "schema": "Project", "description": "Project details" },
    "/projects/{projectId}/milestones/{milestoneId}": { "schema": "Milestone", "description": "Project milestones" },
    "/submissions/{submissionId}": { "schema": "Submission", "description": "Work submissions" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Financial transactions" }
  }
}
